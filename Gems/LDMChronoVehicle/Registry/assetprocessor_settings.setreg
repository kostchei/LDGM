{
    "Amazon": {
        "AssetProcessor": {
            "Settings": {
                "ScanFolder LDMChronoVehicle/Assets": {
                    "watch": "@GEMROOT:LDMChronoVehicle@/Assets",
                    "recursive": 1,
                    "order": 101
                },
                "ScanFolder LDMChronoVehicle/Registry": {
                    "watch": "@GEMROOT:LDMChronoVehicle@/Registry",
                    "recursive": 1,
                    "order": 102
                }
            }
        }
    }
}
