{
    "Amazon": {
        "AssetProcessor": {
            "Settings": {
                "ScanFolder LDGM/Assets": {
                    "watch": "@GEMROOT:LDGM@/Assets",
                    "recursive": 1,
                    "order": 101
                },
                "ScanFolder LDGM/Registry": {
                    "watch": "@GEMROOT:LDGM@/Registry",
                    "recursive": 1,
                    "order": 102
                }
            }
        }
    }
}
