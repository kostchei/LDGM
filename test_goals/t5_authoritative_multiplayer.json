        "server rejection audit"
      ]
    },
    {
      "id": "T5-CAM-004",
      "category": "camera",
      "priority": "critical",
      "statement": "Network corrections do not create unusable first-person camera motion.",
      "method": "mixed",
      "procedure": [
        "Induce controlled vehicle correction during acceleration, turning and collision.",
        "Record root correction and cockpit camera motion.",
        "Review severe cases."
      ],
      "assertions": [
        {
          "metric": "camera_invalid_frames",
          "operator": "==",
          "target": 0
        },
        {
          "metric": "camera_detaches_from_cockpit",
