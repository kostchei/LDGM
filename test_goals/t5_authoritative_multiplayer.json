  "goals": [
    {
      "id": "T5-NET-001",
      "category": "network",
      "priority": "blocker",
      "statement": "Four players can join, drive, fire and complete a mission under server authority.",
      "method": "mixed",
      "procedure": [
        "Start a dedicated server.",
        "Join four clients.",
        "Run a Level 1 mission with simultaneous driving and firing.",
        "Disconnect and reconnect one client.",
        "Complete the mission."
      ],
      "assertions": [
        {
          "metric": "simultaneous_connected_players",
          "operator": "==",
          "target": 4
        },
        {
          "metric": "mission_completed_after_reconnect",
          "operator": "==",
          "target": true
        },
        {
          "metric": "duplicate_vehicle_or_inventory_count",
          "operator": "==",
          "target": 0
        }
      ],
      "evidence": [
        "server log",
        "client captures",
        "database audit"
      ]
    },
    {
      "id": "T5-NET-002",
      "category": "network",
      "priority": "critical",
      "statement": "The game remains usable under representative latency, packet loss and snapshot reordering.",
      "method": "instrumented",
      "procedure": [
        "Run the four-player scenario at 50, 100 and 200 ms latency.",
        "Repeat at 1%, 5% and 10% packet loss.",
        "Inject snapshot reordering.",
        "Capture correction and disconnect metrics."
      ],
      "assertions": [
        {
          "metric": "network_profiles_executed",
          "operator": "==",
          "target": 7
        },
        {
          "metric": "authority_desync_causing_state_duplication",
          "operator": "==",
          "target": 0
        },
        {
          "metric": "unrecoverable_client_disconnects",
          "operator": "==",
          "target": 0
        }
      ],
      "evidence": [
        "network test report",
        "correction telemetry",
        "server/client logs"
      ]
    },
    {
      "id": "T5-SEC-003",
      "category": "security",
      "priority": "blocker",
      "statement": "The server rejects impossible transforms, ammunition changes, fire rates and inventory requests.",
      "method": "automated",
      "procedure": [
        "Submit forged transforms.",
        "Submit ammunition increases.",
        "Exceed weapon fire rate.",
        "Attempt to install or sell an unowned part."
      ],
      "assertions": [
        {
          "metric": "forged_transform_accept_count",
          "operator": "==",
          "target": 0
        },
        {
          "metric": "forged_ammunition_accept_count",
          "operator": "==",
          "target": 0
        },
        {
          "metric": "invalid_fire_rate_accept_count",
          "operator": "==",
          "target": 0
        },
        {
          "metric": "unowned_item_operation_accept_count",
          "operator": "==",
          "target": 0
        }
      ],
